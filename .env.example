# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# ── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001

# PostgreSQL connection string (Render provides this automatically)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT secrets — generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-at-least-64-random-chars
REFRESH_TOKEN_SECRET=change-me-to-a-different-64-random-chars-secret

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://mainstreet.onrender.com

# Public URL of the app (used in email links)
APP_URL=https://mainstreet.onrender.com

# ── Email (SMTP) ─────────────────────────────────────────────────────────────
# Use SendGrid, Resend, or any SMTP provider
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your-sendgrid-api-key-here
EMAIL_FROM=MainStreet <noreply@mainstreet.com>

# ── Client (Vite) ─────────────────────────────────────────────────────────────
# Set this in client/.env or as a Render env var prefixed with VITE_
VITE_API_URL=https://mainstreet.onrender.com/api

# ── Development only ─────────────────────────────────────────────────────────
# SQLite fallback — only used when DATABASE_URL is not set
# DB_PATH=./server/db/mainstreet.db
