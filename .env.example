# Copy this to .env and fill in your values
# NEVER commit .env to git

# REQUIRED in production
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
REFRESH_TOKEN_SECRET=change-me-to-a-different-long-random-string-at-least-32-chars

# Optional — defaults shown
PORT=3001
NODE_ENV=development

# Path to the SQLite database file.
# In production on Render, point this to your persistent disk mount:
#   DB_PATH=/data/mainstreet.db
DB_PATH=

# Optional: comma-separated browser origins allowed to call the API cross-origin.
# Same-origin production requests are allowed automatically.
ALLOWED_ORIGINS=

# ─── Email (SendGrid SMTP relay) ──────────────────────────────────────────────
# Without these, the app logs emails to stdout instead of sending them — fine
# for local dev. To send real email, sign up at sendgrid.com (free tier sends
# 100/day), verify a single sender, generate an API key with "Mail Send" scope,
# then set:
#
#   SMTP_HOST=smtp.sendgrid.net
#   SMTP_PORT=587
#   SMTP_USER=apikey                           # literal string "apikey"
#   SMTP_PASS=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxx  # your SendGrid API key
#   EMAIL_FROM=MainStreet <you@example.com>    # must match your verified sender
#   APP_URL=https://your-app.onrender.com      # used in email links
#
# See README "Sending real email" for the full walkthrough.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
APP_URL=
